{
  "permissions": {
    "allow": [
      "Bash(git rm json/shared/scripts/upgrade-oci-lxc.sh json/shared/scripts/upgrade-start.sh json/shared/templates/221-upgrade-oci-lxc.json json/shared/templates/231-upgrade-start.json)",
      "Bash(git fetch:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$CLAUDE_PROJECT_DIR/.claude/hooks/mark-backend-edit.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -c '\"$CLAUDE_PROJECT_DIR/.claude/hooks/mark-json-edit.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-backend.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -c '\"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-json.sh\"'"
          }
        ]
      }
    ]
  }
}
