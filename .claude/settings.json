{
  "permissions": {
    "allow": [
      "Bash(git rm json/shared/scripts/upgrade-oci-lxc.sh json/shared/scripts/upgrade-start.sh json/shared/templates/221-upgrade-oci-lxc.json json/shared/templates/231-upgrade-start.json)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/mark-backend-edit.sh" },
          { "type": "command", "command": ".claude/hooks/mark-json-edit.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/validate-backend.sh" },
          { "type": "command", "command": ".claude/hooks/validate-json.sh" }
        ]
      }
    ]
  }
}
