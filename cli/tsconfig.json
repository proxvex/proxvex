{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "sourceMap": true,
    "types": ["vitest", "node"],
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../backend/src/*"],
      "@shared/*.mjs": ["../backend/src/*.mts"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["dist"]
}
