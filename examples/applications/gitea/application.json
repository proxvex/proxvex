{
  "name": "Gitea",
  "description": "Git with a cup of tea! Painless self-hosted all-in-one software development service, including Git hosting, code review, team collaboration, package registry and CI/CD",
  "extends": "oci-image",
  "icon": "32px-Gitea_Logo.svg.png",
  "parameters": [
    "hostname",
    "volumes",
    "envs",
    "rootfs_storage",
    "volume_storage"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "gitea/gitea:{{oci_image_tag}}"
    },
    {
      "id": "uid",
      "value": "0"
    },
    {
      "id": "username",
      "value": "root"
    },
    {
      "id": "ssl.mode",
      "value": "native"
    }
  ],
  "installation": {},
  "url": "https://github.com/go-gitea/gitea",
  "source": "https://github.com/go-gitea/gitea",
  "tags": [
    "development"
  ],
  "supported_addons": [
    "addon-oidc"
  ],
  "oidc_roles": [
    {
      "key": "admin",
      "display_name": "Administrator"
    }
  ],
  "stacktype": [
    "oidc",
    "postgres"
  ]
}