{
  "default": {
    "description": "Gitea with Zitadel OIDC and Postgres (no SSL)",
    "addons": ["addon-oidc"],
    "cli_timeout": 600,
    "wait_seconds": 60,
    "verify": {
      "container_running": true,
      "notes_managed": true,
      "services_up": true,
      "docker_log_no_errors": true
    }
  },
  "ssl": {
    "description": "Gitea with SSL, Zitadel SSL, Postgres SSL",
    "addons": ["addon-oidc", "addon-ssl"],
    "cli_timeout": 600,
    "wait_seconds": 60,
    "verify": {
      "container_running": true,
      "notes_managed": true,
      "services_up": true,
      "docker_log_no_errors": true,
      "tls_connect": 3000
    }
  }
}
