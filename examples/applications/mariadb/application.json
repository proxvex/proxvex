{
  "name": "MariaDB",
  "description": "MariaDB is an open source relational database management system.",
  "extends": "oci-image",
  "icon": "icon.svg",
  "parameters": [
    "hostname",
    "volumes",
    "envs"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "mariadb:{{oci_image_tag}}"
    },
    {
      "id": "uid",
      "value": "999"
    },
    {
      "id": "username",
      "value": "root"
    }
  ],
  "installation": {
    "pre_start": [
      "0-upload-server-crt.json",
      "1-upload-server-key.json",
      "2-upload-ssl-cnf.json"
    ]
  },
  "url": "https://github.com/MariaDB/mariadb-docker",
  "documentation": "https://hub.docker.com/_/mariadb/",
  "source": "https://github.com/MariaDB/mariadb-docker",
  "vendor": "MariaDB Community",
  "tags": [
    "database"
  ]
}