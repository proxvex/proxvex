{
  "name": "Upload ssl.cnf",
  "description": "Uploads ssl.cnf to conf.d:ssl.cnf",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_ssl_cnf_content"
  ],
  "parameters": [
    "upload_ssl_cnf_content",
    "upload_ssl_cnf_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload ssl.cnf",
      "script": "2-upload-ssl-cnf.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_ssl_cnf_uploaded"
      ]
    }
  ]
}