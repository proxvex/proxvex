{
  "name": "node-red",
  "description": "Node-RED is a flow-based programming tool for wiring together hardware devices, APIs and online services.",
  "extends": "oci-image",
  "icon": "icon.svg",
  "parameters": [
    "hostname",
    "volumes",
    "envs"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "nodered/node-red:latest"
    },
    {
      "id": "uid",
      "value": "1000"
    },
    {
      "id": "username",
      "value": "root"
    }
  ],
  "installation": {
    "pre_start": [
      "0-upload-settings-js.json",
      "1-upload-server-crt.json",
      "2-upload-server-key.json"
    ]
  },
  "source": "https://github.com/node-red/node-red-docker",
  "tags": [
    "api",
    "iot"
  ]
}