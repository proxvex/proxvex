{
  "name": "Upload settings.js",
  "description": "Uploads settings.js to data:settings.js",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_settings_js_content"
  ],
  "parameters": [
    "upload_settings_js_content",
    "upload_settings_js_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload settings.js",
      "script": "0-upload-settings-js.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_settings_js_uploaded"
      ]
    }
  ]
}