{
  "name": "Upload server.crt",
  "description": "Uploads server.crt to certs:server.crt",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_server_crt_content"
  ],
  "parameters": [
    "upload_server_crt_content",
    "upload_server_crt_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload server.crt",
      "script": "1-upload-server-crt.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_server_crt_uploaded"
      ]
    }
  ]
}