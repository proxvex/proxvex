{
  "name": "Upload server.key",
  "description": "Uploads server.key to certs:server.key",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_server_key_content"
  ],
  "parameters": [
    "upload_server_key_content",
    "upload_server_key_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload server.key",
      "script": "2-upload-server-key.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_server_key_uploaded"
      ]
    }
  ]
}