{
  "name": "pgAdmin",
  "description": "pgAdmin is a feature-rich open source administration and development platform for PostgreSQL.",
  "extends": "oci-image",
  "icon": "pgadmin_94126.svg",
  "parameters": [
    "hostname",
    "volumes",
    "envs"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "dpage/pgadmin4:{{oci_image_tag}}"
    },
    {
      "id": "uid",
      "value": "5050"
    },
    {
      "id": "username",
      "value": "pgadmin"
    }
  ],
  "installation": {
    "pre_start": [
      "0-upload-server-cert.json",
      "1-upload-server-key.json"
    ]
  },
  "supported_addons": [
    "addon-oidc"
  ],
  "oidc_roles": [
    {
      "key": "admin",
      "display_name": "Administrator"
    }
  ],
  "tags": [
    "database"
  ],
  "stacktype": "postgres"
}