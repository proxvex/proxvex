{
  "name": "phpMyAdmin",
  "description": "phpMyAdmin is a web-based MySQL/MariaDB administration tool.",
  "extends": "oci-image",
  "icon": "icon.svg",
  "parameters": [
    "hostname",
    "volumes",
    "envs"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "phpmyadmin:{{oci_image_tag}}"
    },
    {
      "id": "uid",
      "value": "0"
    },
    {
      "id": "username",
      "value": "root"
    }
  ],
  "installation": {},
  "url": "https://github.com/phpmyadmin/docker#readme",
  "documentation": "https://github.com/phpmyadmin/docker#readme",
  "source": "https://github.com/phpmyadmin/docker.git",
  "vendor": "phpMyAdmin",
  "tags": [
    "database"
  ]
}