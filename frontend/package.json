{
  "name": "webapp-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port ${FRONTEND_PORT:-4200} --proxy-config proxy.conf.js",
    "start:e2e": "ng serve --port ${FRONTEND_PORT:-4200} --configuration=e2e",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:trace": "playwright show-trace",
    "lint": "ng lint",
    "lint:all": "eslint \"src/**/*.{ts,tsx,js}\" \"tests/**/*.{ts,tsx,js}\" \"cypress/**/*.{ts,tsx,js}\" \"e2e/**/*.{ts,tsx,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js}\" \"tests/**/*.{ts,tsx,js}\" \"cypress/**/*.{ts,tsx,js}\" \"e2e/**/*.{ts,tsx,js}\" --fix",
    "prettier": "prettier --write ."
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/forms": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.0.3",
    "@angular/router": "^21.0.3",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.1.2",
    "@angular-devkit/core": "^20.3.13",
    "@angular/build": "^21.0.2",
    "@angular/cdk": "^20.2.13",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.3",
    "@angular/material": "^20.2.13",
    "@cypress/angular": "^4.1.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.50.0",
    "@types/cypress": "^0.1.6",
    "@vitest/ui": "^4.0.17",
    "angular-eslint": "21.0.1",
    "cypress": "^15.7.1",
    "eslint": "^9.39.1",
    "jsdom": "^24.1.3",
    "marked": "^17.0.1",
    "prettier": "^3.7.4",
    "socket.io-client": "^4.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4",
    "vite": "^7.2.7",
    "vitest": "^4.0.17"
  }
}
