{
  "name": "ACME/Let's Encrypt",
  "description": "Provision trusted TLS certificates via Let's Encrypt using acme.sh with Cloudflare DNS challenge.",
  "tags": ["security", "network"],

  "parameters": [
    {
      "id": "ssl.mode",
      "name": "SSL Mode",
      "type": "enum",
      "required": true,
      "default": "certs",
      "certtype": "server",
      "enumValues": [
        { "name": "Proxy (nginx)", "value": "proxy" },
        { "name": "Native", "value": "native" },
        { "name": "Certificates only", "value": "certs" }
      ],
      "description": "Proxy: nginx reverse proxy handles HTTPS. Native: app configures HTTPS itself. Certs: only provision certificates (no ports, no proxy)."
    },
    {
      "id": "acme.cf_api_token",
      "name": "Cloudflare API Token",
      "type": "string",
      "required": true,
      "secure": true,
      "description": "Cloudflare API token with DNS edit permissions for the target zone."
    },
    {
      "id": "acme.domain",
      "name": "Domain",
      "type": "string",
      "required": true,
      "description": "Fully qualified domain name for the certificate (e.g. app.example.com)."
    },
    {
      "id": "acme.email",
      "name": "Email",
      "type": "string",
      "required": false,
      "default": "",
      "description": "Email address for Let's Encrypt registration and expiry notifications."
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "required": false,
      "default": "",
      "advanced": true,
      "description": "The HTTP port of the application to be proxied."
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "required": false,
      "default": "",
      "advanced": true,
      "description": "The HTTPS port to listen on."
    }
  ],

  "properties": [
    { "id": "acme.addon_volumes", "value": "certs=/etc/ssl/addon,0700,0:0" },
    { "id": "acme.needs_server_cert", "default": "true" },
    { "id": "acme.needs_ca_cert", "default": "false" },
    { "id": "acme.cert_dir", "default": "/etc/ssl/addon" }
  ],

  "installation": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "159-conf-enable-ssl-app.json", "after": "150-conf-create-storage-volumes-for-lxc.json" },
      { "name": "170-conf-add-ssl-capabilities.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "165-conf-register-hookscript.json", "after": "100-conf-create-configure-lxc.json" }
    ],
    "post_start": [
      "332-post-install-on-start-dispatcher.json",
      "342-post-install-acme-renew-on-start.json",
      { "name": "325-post-inject-ssl-proxy-compose.json", "after": "320-post-upload-docker-compose-files.json" },
      "340-post-install-ssl-proxy-on-start.json"
    ]
  },

  "reconfigure": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "159-conf-enable-ssl-app.json", "after": "150-conf-create-storage-volumes-for-lxc.json" },
      { "name": "170-conf-add-ssl-capabilities.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "165-conf-register-hookscript.json", "after": "100-conf-create-configure-lxc.json" }
    ],
    "post_start": [
      "332-post-install-on-start-dispatcher.json",
      "342-post-install-acme-renew-on-start.json",
      { "name": "325-post-inject-ssl-proxy-compose.json", "after": "320-post-upload-docker-compose-files.json" },
      "340-post-install-ssl-proxy-on-start.json"
    ]
  },

  "disable": {
    "pre_start": [
      "158-conf-disable-ssl-app.json"
    ],
    "post_start": [
      "345-post-disable-ssl-proxy.json"
    ]
  },

  "upgrade": [
    "332-post-install-on-start-dispatcher.json",
    "342-post-install-acme-renew-on-start.json",
    "340-post-install-ssl-proxy-on-start.json"
  ],

  "notes_key": "acme"
}
