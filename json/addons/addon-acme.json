{
  "name": "ACME/Let's Encrypt",
  "description": "Provision trusted TLS certificates via Let's Encrypt using acme.sh with Cloudflare DNS challenge.",
  "tags": [
    "security",
    "network"
  ],
  "stacktype": "cloudflare",
  "parameters": [
    "acme_san",
    "acme_email",
    "http_port",
    "https_port",
    "acme_needs_ca_cert",
    "acme_staging"
  ],
  "properties": [
    {
      "id": "acme.addon_volumes",
      "value": "certs=/etc/ssl/addon,0700,0:0\nproxvex=/etc/proxvex,0755,0:0"
    },
    {
      "id": "acme.cert_dir",
      "value": "/etc/ssl/addon"
    },
    {
      "id": "has_on_start_hooks",
      "value": "true"
    },
    {
      "id": "cert_check_path",
      "value": "/etc/ssl/addon/fullchain.pem"
    },
    {
      "id": "cert_expected_issuer_pattern",
      "value": "Let.s Encrypt"
    }
  ],
  "installation": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "position": "end" },
      { "name": "166-conf-write-on-start-scripts.json", "position": "end" },
      { "name": "159-conf-enable-ssl-app.json", "position": "end" },
      { "name": "170-conf-add-ssl-capabilities.json", "position": "end" },
      { "name": "165-conf-register-hookscript.json", "position": "end" }
    ],
    "post_start": [
      "342-post-install-acme-renew-on-start.json"
    ]
  },
  "reconfigure": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "position": "end" },
      { "name": "166-conf-write-on-start-scripts.json", "position": "end" },
      { "name": "159-conf-enable-ssl-app.json", "position": "end" },
      { "name": "170-conf-add-ssl-capabilities.json", "position": "end" },
      { "name": "165-conf-register-hookscript.json", "position": "end" }
    ],
    "post_start": [
      "342-post-install-acme-renew-on-start.json"
    ]
  },
  "disable": {
    "pre_start": [
      "158-conf-disable-ssl-app.json",
      "167-conf-remove-on-start-scripts.json"
    ]
  },
  "upgrade": [
    "166-conf-write-on-start-scripts.json"
  ],
  "check": [
    "945-host-check-cert-issuer.json"
  ],
  "notes_key": "acme",
  "stack_usage": [
    {
      "stacktype": "cloudflare",
      "vars": [
        {
          "name": "CF_TOKEN",
          "replacement": "on-start-env",
          "script": "acme-renew.sh",
          "script_var": "CF_API_TOKEN",
          "description": "Token is baked into the generated acme-renew.sh during install. On rotation we patch the CF_API_TOKEN line so acme.sh picks up the new token on next container start (or after restarting the renewal loop)."
        }
      ]
    }
  ]
}
