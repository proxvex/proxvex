{
  "name": "mTLS Client Certificates",
  "description": "Issue per-user client certificates signed by the project root CA into /etc/mtls/<CN>/.",
  "tags": [
    "security",
    "network"
  ],
  "parameters": [
    "mtls_cns"
  ],
  "properties": [
    {
      "id": "mtls.addon_volumes",
      "value": "mtls=/etc/mtls,0700"
    },
    {
      "id": "mtls.check_file_paths",
      "value": "/etc/mtls/{{ hostname }}/cert.pem"
    }
  ],
  "installation": {
    "pre_start": [
      { "name": "161-conf-generate-mtls-certs.json", "position": "end" }
    ]
  },
  "reconfigure": {
    "pre_start": [
      { "name": "161-conf-generate-mtls-certs.json", "position": "end" }
    ]
  },
  "disable": {
    "pre_start": []
  },
  "upgrade": [],
  "check": [
    "940-host-check-file-exists.json"
  ],
  "notes_key": "mtls"
}
