{
  "name": "OIDC Authentication",
  "description": "Enable OpenID Connect authentication via Zitadel. Automatically creates an OIDC client in Zitadel and provides credentials as template variables.",
  "tags": [
    "security",
    "authentication"
  ],
  "stacktype": "oidc",
  "parameters": [
    "oidc_app_name",
    "oidc_project_name",
    "oidc_client_id",
    "oidc_client_secret",
    "oidc_issuer_url",
    "oidc_redirect_uri",
    "oidc_post_logout_uri"
  ],
  "dependencies": [
    {
      "application": "zitadel"
    }
  ],
  "properties": [],
  "installation": {
    "pre_start": [
      "150-conf-setup-oidc-client.json",
      "162-conf-configure-oidc-app.json"
    ],
    "post_start": [
      "354-post-trust-oci-ca-in-system.json",
      "355-post-configure-oidc-app.json"
    ]
  },
  "reconfigure": {
    "pre_start": [
      "150-conf-setup-oidc-client.json",
      "162-conf-configure-oidc-app.json"
    ],
    "post_start": [
      "354-post-trust-oci-ca-in-system.json",
      "355-post-configure-oidc-app.json"
    ]
  },
  "disable": {
    "pre_start": [
      "162-conf-disable-oidc-app.json"
    ]
  },
  "notes_key": "oidc"
}
