{
  "name": "SSL/HTTPS",
  "description": "Enable HTTPS via nginx reverse proxy, native app configuration, or certificate provisioning only.",
  "tags": [
    "security",
    "network"
  ],
  "parameters": [
    "ssl_mode",
    "http_port",
    "https_port"
  ],
  "properties": [
    {
      "id": "ssl.addon_volumes",
      "value": "certs=/etc/ssl/addon,0700\nproxvex=/etc/proxvex,0755"
    },
    {
      "id": "has_on_start_hooks",
      "value": "true"
    }
  ],
  "installation": {
    "pre_start": [
      {
        "name": "156-conf-generate-certificates.json",
        "after": "150-conf-create-storage-volumes-for-lxc.json"
      },
      {
        "name": "157-conf-publish-ssl-provides.json",
        "after": "156-conf-generate-certificates.json"
      },
      {
        "name": "166-conf-write-on-start-scripts.json",
        "after": "150-conf-create-storage-volumes-for-lxc.json"
      },
      {
        "name": "159-conf-enable-ssl-app.json",
        "after": "156-conf-generate-certificates.json"
      },
      {
        "name": "170-conf-add-ssl-capabilities.json",
        "after": "100-conf-create-configure-lxc.json"
      },
      {
        "name": "165-conf-register-hookscript.json",
        "after": "100-conf-create-configure-lxc.json"
      }
    ]
  },
  "reconfigure": {
    "pre_start": [
      {
        "name": "156-conf-generate-certificates.json",
        "after": "150-conf-create-storage-volumes-for-lxc.json"
      },
      {
        "name": "157-conf-publish-ssl-provides.json",
        "after": "156-conf-generate-certificates.json"
      },
      {
        "name": "166-conf-write-on-start-scripts.json",
        "after": "150-conf-create-storage-volumes-for-lxc.json"
      },
      {
        "name": "159-conf-enable-ssl-app.json",
        "after": "156-conf-generate-certificates.json"
      },
      {
        "name": "170-conf-add-ssl-capabilities.json",
        "after": "100-conf-create-configure-lxc.json"
      },
      {
        "name": "165-conf-register-hookscript.json",
        "after": "100-conf-create-configure-lxc.json"
      }
    ]
  },
  "disable": {
    "pre_start": [
      "158-conf-disable-ssl-app.json",
      "167-conf-remove-on-start-scripts.json"
    ]
  },
  "upgrade": [
    "166-conf-write-on-start-scripts.json"
  ],
  "notes_key": "ssl"
}
