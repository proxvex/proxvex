{
  "name": "docker-compose",
  "description": "Base application for Docker Compose based services",
  "supported_addons": [
    "addon-ssl",
    "samba-shares"
  ],
  "supports": [
    "docker"
  ],
  "parameters": [
    "ostype"
  ],
  "properties": [
    {
      "id": "oci_image",
      "value": "ghcr.io/proxvex/debian-docker:latest"
    },
    {
      "id": "oidc_redirect_uri",
      "default": "https://{{hostname}}{{project_domain_suffix}}/api/auth/callback"
    },
    {
      "id": "oidc_post_logout_uri",
      "default": "https://{{hostname}}{{project_domain_suffix}}"
    }
  ],
  "installation": {
    "image": [
      "011-host-get-oci-image.json",
      "095-host-check-kernel-modules.json",
      "096-host-load-kernel-modules.json"
    ],
    "create_ct": [
      {
        "name": "050-set-project-parameters.json",
        "category": "create_ct"
      },
      {
        "name": "100-conf-create-configure-lxc.json",
        "category": "pre_start"
      }
    ],
    "pre_start": [
      "101-conf-configure-lxc-for-docker.json",
      {
        "name": "310-post-extract-volumes-from-compose.json",
        "category": "post_start"
      },
      "121-conf-mount-zfs-pool-on-host.json",
      "185-host-resolve-dependency-hosts.json",
      "108-host-push-ca-to-container.json"
    ],
    "pre_start_finalize": [
      "100-conf-unmount-volumes.json"
    ],
    "start": [
      "200-start-lxc.json"
    ],
    "post_start": [
      "305-post-set-pkg-mirror.json",
      "307-post-start-dockerd.json",
      "320-post-upload-docker-compose-files.json",
      "330-svc-start-docker-compose.json",
      "335-post-update-version-from-docker.json",
      "350-host-check-hook-log.json"
    ]
  },
  "upgrade": {
    "post_start": [
      "315-post-update-compose-image-tags.json",
      "316-post-upgrade-system-packages.json",
      "317-svc-upgrade-docker-compose.json",
      "335-post-update-version-from-docker.json"
    ]
  },
  "reconfigure": {
    "image": [
      "012-host-docker-pull-in-existing.json"
    ],
    "create_ct": [
      "100-create-ct-clone.json"
    ],
    "pre_start": [
      "150-conf-create-storage-volumes-for-lxc.json",
      "101-conf-configure-lxc-for-docker.json",
      {
        "name": "310-post-extract-volumes-from-compose.json",
        "category": "post_start"
      },
      "121-conf-mount-zfs-pool-on-host.json",
      "185-host-resolve-dependency-hosts.json",
      "108-host-push-ca-to-container.json",
      "191-host-write-docker-compose-notes.json"
    ],
    "pre_start_finalize": [
      "100-conf-unmount-volumes.json"
    ],
    "start": [
      "200-start-lxc.json"
    ],
    "post_start": [
      "305-post-set-pkg-mirror.json",
      "307-post-start-dockerd.json",
      "320-post-upload-docker-compose-files.json",
      "330-svc-start-docker-compose.json",
      "335-post-update-version-from-docker.json",
      "350-host-check-hook-log.json"
    ],
    "replace_ct": [
      "900-replace-ct.json"
    ]
  },
  "check": {
    "check": [
      "900-host-check-container.json",
      "910-host-check-docker-services.json",
      "915-host-check-docker-image-versions.json",
      "920-host-check-lxc-log.json",
      "930-host-check-docker-logs.json",
      "940-host-check-file-exists.json",
      "945-check-https-cert.json",
      "950-host-check-tls-connect.json",
      "965-check-oidc-discovery.json",
      "975-check-oidc-redirect-ready.json",
      "990-host-check-volume-consistency.json"
    ]
  }
}
