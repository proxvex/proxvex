{
  "name": "Docker Registry Mirror",
  "description": "Pull-through cache for Docker Hub. Caches images locally to avoid rate limits.",
  "extends": "oci-image",
  "icon": "icon.svg",
  "parameters": [
    "DOCKER_HUB_USERNAME"
  ],
  "properties": [
    {
      "id": "hostname",
      "default": "docker-registry-mirror"
    },
    {
      "id": "oci_image",
      "value": "distribution/distribution:{{oci_image_tag}}"
    },
    {
      "id": "uid",
      "value": "0"
    },
    {
      "id": "gid",
      "value": "0"
    },
    {
      "id": "username",
      "value": "root"
    },
    {
      "id": "volumes",
      "default": "data=/var/lib/registry,size=5G"
    },
    {
      "id": "envs",
      "default": "REGISTRY_HTTP_ADDR=:443\nREGISTRY_HTTP_TLS_CERTIFICATE=/etc/ssl/addon/fullchain.pem\nREGISTRY_HTTP_TLS_KEY=/etc/ssl/addon/privkey.pem\nREGISTRY_PROXY_REMOTEURL=https://registry-1.docker.io\nREGISTRY_PROXY_USERNAME={{ DOCKER_HUB_USERNAME }}\nREGISTRY_PROXY_PASSWORD={{ DOCKER_HUB_PASSWORD }}"
    },
    {
      "id": "ssl_mode",
      "value": "native"
    },
    {
      "id": "local_https_port",
      "value": "443"
    },
    {
      "id": "ssl.needs_server_cert",
      "value": "true"
    },
    {
      "id": "ssl.needs_ca_cert",
      "value": "false"
    },
    {
      "id": "ssl_additional_san",
      "value": "DNS:registry-1.docker.io,DNS:index.docker.io"
    },
    {
      "id": "wait_for_network",
      "value": "true"
    },
    {
      "id": "startup_order",
      "value": "5"
    },
    {
      "id": "startup_up",
      "value": "10"
    }
  ],
  "installation": {},
  "check": {
    "check": [
      "check-registry-mirror.json"
    ]
  },
  "supported_addons": [
    "addon-ssl"
  ],
  "required_addons": [
    "addon-ssl"
  ],
  "stacktype": "dockermr",
  "stack_usage": [
    {
      "stacktype": "dockermr",
      "vars": [
        {
          "name": "DOCKER_HUB_PASSWORD",
          "replacement": "lxc-config-env",
          "lxc_var_name": "REGISTRY_PROXY_PASSWORD"
        }
      ]
    }
  ],
  "tags": [
    "infrastructure"
  ],
  "url": "https://docs.docker.com/registry/",
  "documentation": "https://docs.docker.com/registry/recipes/mirror/",
  "source": "https://github.com/distribution/distribution"
}
