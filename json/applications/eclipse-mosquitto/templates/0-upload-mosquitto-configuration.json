{
  "name": "Upload Mosquitto Configuration",
  "description": "Uploads Mosquitto Configuration to config:mosquitto.conf",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_mosquitto_configuration_content"
  ],
  "parameters": [
    "upload_mosquitto_configuration_content",
    "upload_mosquitto_configuration_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload Mosquitto Configuration",
      "script": "0-upload-mosquitto-configuration.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_mosquitto_configuration_uploaded"
      ]
    }
  ]
}