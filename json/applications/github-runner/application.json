{
  "name": "GitHub Actions Runner",
  "description": "Self-hosted GitHub Actions runner. Registers itself with the configured repo on container start and pre-runs Docker-in-LXC for workflows that build images (e.g. step2b-install-deployer.sh).",
  "extends": "oci-image",
  "icon": "icon.svg",
  "tags": [
    "ci",
    "devops",
    "infrastructure"
  ],
  "parameters": [
    "REPO_URL",
    "ACCESS_TOKEN",
    "RUNNER_NAME",
    "LABELS"
  ],
  "properties": [
    {
      "id": "hostname",
      "default": "gh-runner"
    },
    {
      "id": "oci_image",
      "value": "ghcr.io/proxvex/github-actions-runner:{{oci_image_tag}}"
    },
    {
      "id": "memory",
      "default": 8192
    },
    {
      "id": "disk_size",
      "default": "16"
    },
    {
      "id": "uid",
      "value": "0"
    },
    {
      "id": "gid",
      "value": "0"
    },
    {
      "id": "username",
      "value": "root"
    },
    {
      "id": "wait_for_network",
      "value": "true"
    },
    {
      "id": "envs",
      "default": "REPO_URL={{ REPO_URL }}\nACCESS_TOKEN={{ ACCESS_TOKEN }}\nRUNNER_NAME={{ RUNNER_NAME }}\nLABELS={{ LABELS }}\nRUNNER_ALLOW_RUNASROOT=1\nRUNNER_SECRETS_DIR=/var/lib/gh-runner-secrets"
    },
    {
      "id": "volumes",
      "default": "secrets=/var/lib/gh-runner-secrets,0700"
    }
  ],
  "installation": {
    "pre_start": [
      "101-conf-configure-lxc-for-docker.json"
    ]
  },
  "url": "https://github.com/proxvex/proxvex",
  "documentation": "https://github.com/proxvex/proxvex/tree/main/json/applications/github-runner",
  "source": "https://github.com/proxvex/proxvex/tree/main/e2e/infrastructure/github-runner"
}
