{
  "name": "Upload flows.json",
  "description": "Optionally uploads flows.json to data:flows.json. Skipped if no content provided.",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "upload_flows_json_content"
  ],
  "parameters": [
    "upload_flows_json_content",
    "upload_flows_json_destination",
    "shared_volpath",
    "hostname",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid"
  ],
  "commands": [
    {
      "name": "Upload flows.json",
      "script": "1-upload-flows-json.sh",
      "library": "upload-file-common.sh",
      "outputs": [
        "upload_flows_json_uploaded"
      ]
    }
  ]
}
