{
  "name": "oci-image",
  "description": "Base application for OCI image based services",
  "icon": "icon.png",
  "supported_addons": ["addon-ssl", "addon-acme", "samba-shares"],
  "installation": {
    "image": [
      "011-host-get-oci-image.json"
    ],
    "create_ct": [
      { "name": "050-set-project-parameters.json", "category": "create_ct" },
      { "name": "185-host-resolve-dependency-hosts.json", "category": "pre_start" },
      { "name": "187-create-postgres-database.json", "category": "pre_start" },
      { "name": "100-conf-create-configure-lxc.json", "category": "pre_start" }
    ],
    "pre_start": [
      "108-host-push-ca-to-container.json",
      "107-conf-oci-lxc-configuration.json"
    ],
    "pre_start_finalize": [
      "100-conf-unmount-volumes.json"
    ],
    "start": [
      "200-start-lxc.json",
      "210-wait-for-container-ready.json"
    ],
    "post_start": [
      "305-post-set-pkg-mirror.json",
      "350-host-check-hook-log.json"
    ]
  },
  "upgrade": {
    "image": [
      "011-host-get-oci-image.json"
    ],
    "create_ct": [
      { "name": "050-set-project-parameters.json", "category": "create_ct" },
      { "name": "100-conf-create-configure-lxc.json", "category": "pre_start" }
    ],
    "pre_start": [
      "108-host-push-ca-to-container.json",
      "101-conf-restore-settings.json",
      "107-conf-oci-lxc-configuration.json"
    ],
    "pre_start_finalize": [
      "100-conf-unmount-volumes.json"
    ],
    "start": [
      "200-start-lxc.json",
      "210-wait-for-container-ready.json"
    ],
    "post_start": [
      "305-post-set-pkg-mirror.json",
      "350-host-check-hook-log.json"
    ],
    "replace_ct": [
      "900-replace-ct.json"
    ]
  },
  "reconfigure": {
    "create_ct": [
      "100-create-ct-clone.json"
    ],
    "pre_start": [
      "set-reconfigure-defaults.json",
      "108-host-push-ca-to-container.json",
      "150-conf-create-storage-volumes-for-lxc.json",
      "185-host-resolve-dependency-hosts.json",
      "190-host-write-lxc-notes.json"
    ],
    "pre_start_finalize": [
      "100-conf-unmount-volumes.json"
    ],
    "start": [
      "200-start-lxc.json",
      "210-wait-for-container-ready.json"
    ],
    "post_start": [
      "350-host-check-hook-log.json"
    ],
    "replace_ct": [
      "900-replace-ct.json"
    ]
  },
  "check": {
    "check": [
      "900-host-check-container.json",
      "920-host-check-lxc-log.json",
      "940-host-check-file-exists.json",
      "950-host-check-tls-connect.json",
      "990-host-check-volume-consistency.json"
    ]
  }
}