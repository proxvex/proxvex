{
  "default": {
    "depends_on": ["zitadel/default"],
    "wait_seconds": 30,
    "cli_timeout": 360
  },
  "upgrade": {
    "task": "upgrade",
    "depends_on": ["oci-lxc-deployer/default"],
    "wait_seconds": 30,
    "cli_timeout": 360
  },
  "plain": {
    "wait_seconds": 30,
    "cli_timeout": 360,
    "description": "Install deployer without addons (base for reconfigure tests)"
  },
  "reconf-oidc": {
    "task": "reconfigure",
    "depends_on": ["oci-lxc-deployer/plain", "zitadel/default"],
    "wait_seconds": 30,
    "cli_timeout": 360,
    "description": "Reconfigure: enable SSL and OIDC addon on existing deployer container"
  }
}
