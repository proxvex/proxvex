{
  "default": {
    "depends_on": ["zitadel/default"],
    "addons": ["addon-oidc"],
    "wait_seconds": 30,
    "cli_timeout": 360,
    "params": [
      { "name": "check_oidc_enabled", "value": "true" },
      { "name": "check_oidc_api_protected", "value": "true" },
      { "name": "check_oidc_machine_login", "value": "true" },
      { "name": "dep_zitadel_vm_id", "value": "{{ dep_zitadel_vm_id }}" }
    ]
  },
  "upgrade": {
    "task": "upgrade",
    "depends_on": ["oci-lxc-deployer/default"],
    "wait_seconds": 30,
    "cli_timeout": 360
  }
}
