{
  "name": "pgAdmin",
  "description": "Web-based administration and development platform for PostgreSQL",
  "extends": "oci-image",
  "icon": "icon.svg",
  "tags": [
    "database"
  ],
  "stacktype": "pgadmin",
  "parameters": [
    "http_port",
    "local_https_port"
  ],
  "properties": [
    {
      "id": "hostname",
      "default": "pgadmin"
    },
    {
      "id": "oci_image",
      "value": "dpage/pgadmin4"
    },
    {
      "id": "uid",
      "value": "5050"
    },
    {
      "id": "gid",
      "value": "5050"
    },
    {
      "id": "username",
      "value": "pgadmin"
    },
    {
      "id": "envs",
      "default": "PGADMIN_DEFAULT_EMAIL=admin@example.com\nPGADMIN_DEFAULT_PASSWORD={{ PGADMIN_DEFAULT_PASSWORD }}"
    }
  ],
  "installation": {},
  "stack_usage": [
    {
      "stacktype": "pgadmin",
      "vars": [
        {
          "name": "PGADMIN_DEFAULT_PASSWORD",
          "replacement": "manual"
        }
      ]
    }
  ]
}
