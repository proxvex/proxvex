{
  "name": "PostgREST",
  "description": "PostgreSQL REST API server - automatically creates a RESTful API from a PostgreSQL database",
  "extends": "docker-compose",
  "icon": "icon.svg",
  "tags": [
    "api",
    "database"
  ],
  "parameters": [
    "http_port",
    "https_port"
  ],
  "properties": [
    {
      "id": "hostname",
      "default": "postgrest"
    },
    {
      "id": "compose_project",
      "value": "postgrest"
    },
    {
      "id": "compose_file",
      "value": ""
    },
    {
      "id": "ssl_mode",
      "value": "proxy"
    },
    {
      "id": "ssl.needs_server_cert",
      "value": "true"
    },
    {
      "id": "ssl.needs_ca_cert",
      "value": "true"
    }
  ],
  "dependencies": [
    {
      "application": "postgres"
    }
  ],
  "installation": {},
  "stacktype": "postgres",
  "stack_usage": [
    {
      "stacktype": "postgres",
      "vars": [
        {
          "name": "POSTGRES_PASSWORD",
          "replacement": "manual"
        }
      ]
    }
  ]
}
