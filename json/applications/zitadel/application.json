{
  "name": "zitadel",
  "description": "ZITADEL is an open source identity management platform.",
  "extends": "docker-compose",
  "icon": "icon.png",
  "parameters": [
    "ZITADEL_EXTERNALDOMAIN",
    "ZITADEL_EXTERNALSECURE",
    "ZITADEL_EXTERNALPORT",
    "ZITADEL_FORWARDED_PROTO",
    "ZITADEL_PUBLIC_BASE_URL",
    "smtp_own_domain",
    "smtp_mail_domain",
    "smtp_mx_target",
    "smtp_spf_value"
  ],
  "properties": [
    {
      "id": "hostname",
      "default": "zitadel"
    },
    {
      "id": "volumes",
      "default": "bootstrap=bootstrap,0750,1000:1001"
    },
    {
      "id": "disk_size",
      "value": "4"
    },
    {
      "id": "compose_file",
      "default": "file:Zitadel.docker-compose.yml"
    },
    {
      "id": "ostype",
      "value": "alpine"
    },
    {
      "id": "ssl_mode",
      "default": "native"
    },
    {
      "id": "local_https_port",
      "value": "1443"
    },
    {
      "id": "ssl.addon_volumes",
      "value": "certs=certs,0755,0:0\nproxvex=/etc/proxvex,0755,0:0"
    },
    {
      "id": "ssl.needs_server_cert",
      "value": "true"
    },
    {
      "id": "ssl.needs_ca_cert",
      "value": "true"
    },
    {
      "id": "startup_order",
      "value": "20"
    },
    {
      "id": "startup_up",
      "value": "15"
    },
    {
      "id": "startup_timeout",
      "value": "300"
    },
    {
      "id": "check_file_paths",
      "value": "/bootstrap/login-client.pat\n/bootstrap/admin-client.pat"
    }
  ],
  "dependencies": [
    {
      "application": "postgres"
    }
  ],
  "installation": {
    "pre_start": [
      "160-conf-strip-empty-smtp.json"
    ],
    "post_start": [
      "325-conf-check-zitadel-state-consistency.json",
      "340-post-setup-deployer-in-zitadel.json",
      "385-post-configure-mail-dns.json",
      "380-post-show-admin-credentials.json"
    ]
  },
  "stacktype": [
    "postgres",
    "oidc",
    "cloudflare"
  ],
  "stack_usage": [
    {
      "stacktype": "cloudflare",
      "vars": [
        {
          "name": "CF_TOKEN",
          "replacement": "no-action",
          "description": "DNS records are set at install time via 385-post-configure-mail-dns.json. Rotating CF_TOKEN changes only the API credential, not the DNS content — no per-container action required."
        }
      ]
    },
    {
      "stacktype": "postgres",
      "vars": [
        {
          "name": "POSTGRES_PASSWORD",
          "replacement": "compose-env",
          "compose_key": "ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD"
        }
      ]
    },
    {
      "stacktype": "oidc",
      "vars": [
        {
          "name": "ZITADEL_MASTERKEY",
          "replacement": "manual"
        },
        {
          "name": "ZITADEL_DB_PASSWORD",
          "replacement": "compose-env",
          "compose_key": "ZITADEL_DATABASE_POSTGRES_USER_PASSWORD"
        },
        {
          "name": "ZITADEL_ADMIN_PASSWORD",
          "replacement": "manual"
        },
        {
          "name": "SMTP_PASSWORD",
          "replacement": "compose-env",
          "compose_key": "ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_PASSWORD"
        }
      ]
    }
  ]
}
