    "docker_registry_mirror": {
      "name": "Docker Hub Registry Mirror URL",
      "description": "Optional pull-through cache URL for Docker Hub (e.g. https://docker-registry-mirror). When set as a project default, post-start-dockerd.sh adds it to /etc/docker/daemon.json `registry-mirrors` so docker.io pulls from any docker-compose-based application go via the mirror instead of hitting Docker Hub directly. Empty disables the feature.",
      "type": "string",
      "default": "",
      "internal": true,
      "project": true
    },
    "ghcr_registry_mirror": {
      "name": "ghcr.io Registry Mirror URL",
      "description": "Optional pull-through cache URL for ghcr.io (e.g. https://zot-mirror). Docker has no per-registry mirror switch, so post-start-dockerd.sh installs an /etc/hosts redirect: ghcr.io -> the mirror's IP. The mirror's TLS cert must include 'DNS:ghcr.io' in its SAN — the proxvex zot-mirror app does this by default. Empty disables the feature.",
      "type": "string",
      "default": "",
      "internal": true,
      "project": true
    },
