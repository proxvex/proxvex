{
  "execute_on": "ve",
  "name": "Clone Container",
  "description": "Creates a new LXC container by cloning an existing one. Used for reconfigure tasks where the OS image stays the same but configuration changes.",
  "parameters": [
    "previous_vm_id",
    "vm_id",
    "vm_id_start",
    "searchdomain"
  ],
  "commands": [
    {
      "template": "050-set-project-parameters.json"
    },
    {
      "name": "Clone Container",
      "script": "create-ct-clone.sh",
      "library": "upgrade-common.sh",
      "outputs": [
        "vm_id",
        "previous_vm_id",
        "installed_addons",
        "volume_storage",
        "hostname"
      ]
    }
  ]
}
