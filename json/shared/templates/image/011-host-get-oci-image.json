{
  "execute_on": "ve",
  "name": "Get OCI Image",
  "description": "Download OCI image from Docker Registry and import to Proxmox storage",
  "skip_if_property_set": "template_path",
  "parameters": [
    "oci_image",
    "oci_image_tag",
    "storage",
    "platform",
    "target_versions",
    "registry_username",
    "registry_password",
    "registry_token"
  ],
  "commands": [
    {
      "name": "Get OCI Image",
      "script": "host-get-oci-image.py",
      "library": "oci_version_lib.py",
      "outputs": [
        "template_path",
        "ostype",
        "arch",
        "application_id",
        "application_name",
        "oci_image",
        "oci_image_tag"
      ]
    }
  ]
}