{
  "name": "Update Version from Docker",
  "description": "Reads the actual Docker image version after pull and updates the LXC notes. Runs on the PVE host (post_start).",
  "execute_on": "ve",
  "parameters": [
    "vm_id",
    "application_id"
  ],
  "commands": [
    {
      "name": "Update Version from Docker",
      "script": "post-update-version-from-docker.py",
      "library": [
        "oci_version_lib.py",
        "lxc_config_parser_lib.py"
      ],
      "outputs": [
        "app_version"
      ]
    }
  ]
}
