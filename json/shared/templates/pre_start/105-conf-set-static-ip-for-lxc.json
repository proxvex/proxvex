{
  "execute_on": "ve",
  "name": "Static IP for LXC",
  "description": "Edit LXC network settings for a container with static IPs.",
  "skip_if_all_missing": [
    "static_ip",
    "static_ip6",
    "nameserver4"
  ],
  "parameters": [
    "static_ip",
    "static_gw",
    "static_ip6",
    "static_gw6",
    "nameserver4",
    "nameserver6",
    "vm_id",
    "hostname",
    "bridge"
  ],
  "commands": [
    {
      "name": "lxc-static-ip",
      "script": "conf-lxc-static-ip.sh"
    }
  ]
}