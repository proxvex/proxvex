{
  "execute_on": "ve",
  "name": "Map Serial Device",
  "description": "Map serial device to VM",
  "implements": "serial_tty",
  "skip_if_all_missing": [
    "host_device_path"
  ],
  "parameters": [
    "host_device_path",
    "install_replug_watcher",
    "vm_id",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid",
    "container_device_path"
  ],
  "commands": [
    {
      "name": "Map Serial Device",
      "script": "conf-map-serial-device.py",
      "library": "map_device_lib.py"
    }
  ]
}