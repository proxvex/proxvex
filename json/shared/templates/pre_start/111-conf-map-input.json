{
  "execute_on": "ve",
  "name": "Map Input Device",
  "description": "Map input device (keyboard/mouse) to LXC container or VM",
  "skip_if_all_missing": [
    "usb_bus_device"
  ],
  "parameters": [
    "usb_bus_device",
    "vm_id",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid",
    "container_device_paths"
  ],
  "commands": [
    {
      "name": "Map Input Device",
      "script": "conf-map-input-device.sh",
      "library": "usb-device-common.sh"
    }
  ]
}