{
  "name": "Create Storage Volumes for LXC",
  "description": "Creates Proxmox storage volumes (mpX) and attaches them to the container. Volumes are named by hostname and can be shared across CTs.",
  "execute_on": "ve",
  "skip_if_all_missing": [
    "volumes",
    "addon_volumes"
  ],
  "parameters": [
    "vm_id",
    "hostname",
    "volumes",
    "addon_volumes",
    "volume_storage",
    "volume_size",
    "volume_backup",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid",
    "previous_vm_id"
  ],
  "commands": [
    {
      "name": "Create Storage Volumes",
      "script": "conf-create-storage-volumes-for-lxc.sh",
      "library": [
        "pve-common.sh",
        "vol-common.sh"
      ],
      "outputs": [
        "volumes_attached",
        "cert_dir_override"
      ]
    }
  ]
}