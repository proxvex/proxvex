{
  "name": "Setup OIDC Client",
  "description": "Create or retrieve an OIDC client application in Zitadel. Outputs oidc_issuer_url, oidc_client_id, and oidc_client_secret as template variables. Runs on PVE host before container start so credentials are available to pre_start templates.",
  "execute_on": "ve",
  "parameters": [
    "ZITADEL_HOST",
    "hostname",
    "oidc_app_name",
    "oidc_redirect_uri",
    "oidc_post_logout_uri",
    "oidc_project_name",
    "oidc_issuer_url",
    "ZITADEL_PAT",
    "DEPLOYER_OIDC_MACHINE_CLIENT_ID",
    "DEPLOYER_OIDC_MACHINE_CLIENT_SECRET",
    "DEPLOYER_OIDC_ISSUER_URL",
    "DEPLOYER_OIDC_PROJECT_ID",
    "oidc_roles"
  ],
  "commands": [
    {
      "name": "Setup OIDC Client",
      "script": "conf-setup-oidc-client.sh",
      "outputs": [
        "oidc_issuer_url",
        "oidc_client_id",
        "oidc_client_secret",
        "oidc_bearer_source"
      ]
    }
  ]
}
