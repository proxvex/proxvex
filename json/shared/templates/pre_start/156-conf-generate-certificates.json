{
  "execute_on": "ve",
  "name": "Write Certificates",
  "skip_if_all_missing": [
    "server_cert_b64"
  ],
  "parameters": [
    "vm_id",
    "server_key_b64",
    "server_cert_b64",
    "ca_cert_b64",
    "hostname",
    "project_domain_suffix",
    "ssl.needs_server_cert",
    "ssl.needs_ca_cert",
    "uid",
    "gid",
    "mapped_uid",
    "mapped_gid",
    "cert_dir_override"
  ],
  "commands": [
    {
      "name": "Write Certificates",
      "script": "conf-generate-certificates.sh",
      "library": [
        "pve-common.sh",
        "cert-common.sh"
      ],
      "outputs": [
        "certs_generated"
      ]
    }
  ]
}
