{
  "folders": [
    { "path": "." },
    { "path": "frontend" },
^
    { "path": "backend" }
  ],
  "settings": {
    "window.title": "${activeEditorShort} - oci-lxc-deployer [GREEN]",
    "workbench.colorCustomizations": {
    // Hintergrund des Editors
    "activityBar.background": "#71e971",
    "activityBar.foreground": "#130d03",},
    "claudeCode.allowDangerouslySkipPermissions": true,
    "terminal.integrated.env.osx": {
      "DEPLOYER_PORT": "3201",
      "FRONTEND_PORT": "4301"
    }
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "build backend",
        "type": "shell",
        "command": "pnpm run build",
        "options": { "cwd": "${workspaceFolder:backend}" },
        "problemMatcher": ["$tsc"]
      },
      {
        "label": "start frontend",
        "type": "shell",
        "command": "pnpm start",
        "options": { "cwd": "${workspaceFolder:frontend}" },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "Git Workflow",
        "type": "shell",
        "command": "sh",
        "args": ["-c", "${input:gitAction}"],
        "problemMatcher": [],
        "presentation": { "reveal": "always", "focus": true }
      },
      {
        "label": "Git: Create Feature Branch",
        "type": "shell",
        "command": "./scripts/git-create-branch",
        "args": ["${input:branchName}"],
        "problemMatcher": [],
        "presentation": { "reveal": "always", "focus": true }
      }
    ],
    "inputs": [
      {
        "id": "gitAction",
        "type": "pickString",
        "description": "Git Workflow Action",
        "options": [
          { "label": "Rebase on upstream/main", "value": "./scripts/git-rebase" },
          { "label": "Rebase + Push", "value": "./scripts/git-rebase --push" },
          { "label": "Create PR to upstream", "value": "./scripts/git-pr" },
          { "label": "Delete Current Branch", "value": "./scripts/git-delete-branch" }
        ]
      },
      {
        "id": "branchName",
        "type": "promptString",
        "description": "Branch name (auto-prefixes with feat/ if no prefix given)",
        "default": "feat/"
      }
    ]
  },
  "launch": {
    "configurations": [
      {
        "name": "Launch Backend",
        "program": "${workspaceFolder:backend}/dist/oci-lxc-deployer.mjs",
        "preLaunchTask": "build backend",
        "request": "launch",
        "sourceMaps": true,
        "cwd": "${workspaceFolder:backend}",
        "console": "integratedTerminal",
        "args": [
          "--local",
          "${workspaceFolder:backend}/../livetest-local",
          "--storageContextFilePath",
          "${workspaceFolder:backend}/../storagecontext.json",
          "--secretsFilePath",
          "${workspaceFolder:backend}/../secret.txt"
        ],
        "env": {
          "DEPLOYER_PORT": "3201"
        },
        "trace": true,
        "outFiles": [
          "${workspaceFolder:backend}/dist/**/*.mjs",
          "${workspaceFolder:backend}/dist/**/*.mjs.map"
        ],
        "skipFiles": ["<node_internals>/**"],
        "type": "node"
      },
          {
        "name": "Launch OIDC Backend",
        "program": "${workspaceFolder:backend}/dist/oci-lxc-deployer.mjs",
        "preLaunchTask": "build backend",
        "request": "launch",
        "sourceMaps": true,
        "cwd": "${workspaceFolder:backend}",
        "console": "integratedTerminal",
        "args": [
          "--local",
          "${workspaceFolder:backend}/../livetest-local",
          "--storageContextFilePath",
          "${workspaceFolder:backend}/../storagecontext.json",
          "--secretsFilePath",
          "${workspaceFolder:backend}/../secret.txt"
        ],
        "env": {
          "DEPLOYER_PORT": "3201",
          "OIDC_ENABLED": "true",
          "OIDC_ISSUER_URL": "https://auth.ohnewarum.de",
          "OIDC_CLIENT_ID": "369548938576986115",
          "OIDC_CLIENT_SECRET": "l64POaqfgdpl8Q8cb6bja2DhNvEAtSKxhwonWV8VSbql8vksDtAqFC1e3iQgTVel",
          "OIDC_CALLBACK_URL": "http://localhost:3201/api/auth/callback",
          "OIDC_SESSION_SECRET": "a70d851738d983e0d0dfb9847f458ed12bc8c775d87873b0b7ddfcdcf9a38bb0"
        },
        "trace": true,
        "outFiles": [
          "${workspaceFolder:backend}/dist/**/*.mjs",
          "${workspaceFolder:backend}/dist/**/*.mjs.map"
        ],
        "skipFiles": ["<node_internals>/**"],
        "type": "node"
      },
      {
        "name": "ng serve",
        "type": "chrome",
        "request": "launch",
        "preLaunchTask": "start frontend",
        "url": "http://localhost:4301/",
        "webRoot": "${workspaceFolder:frontend}",
        "sourceMapPathOverrides": {
          "webpack:/*": "${webRoot}/*",
          "/./*": "${webRoot}/*",
          "/src/*": "${webRoot}/src/*",
          "/*": "*",
          "/./~/*": "${webRoot}/node_modules/*"
        }
      }
    ]
  }
}
