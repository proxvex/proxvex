{
  "$id": "base-deployable",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Base schema for deployable entities (applications and addons)",
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorization. Must match tags defined in json/tags.json"
    },
    "parameters": {
      "type": "array",
      "description": "Parameter IDs referenced from this deployable. The canonical definition for each ID lives in json/shared/parameter-definitions.json. (Inline objects are accepted as a transitional form for legacy/backup directories.)",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
          },
          {
            "type": "object",
            "$comment": "Legacy inline form — accepted only for backup/transitional templates, not for new code.",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "enum": ["string", "number", "enum", "boolean"] },
              "description": { "type": "string" },
              "multiline": { "type": "boolean" },
              "upload": { "type": "boolean" },
              "certtype": { "type": "string" },
              "required": { "type": "boolean" },
              "secure": { "type": "boolean" },
              "advanced": { "type": "boolean" },
              "default": { "type": ["string", "number", "boolean"] },
              "enumValues": { "type": "array" },
              "enumValuesTemplate": { "type": "string" },
              "if": { "type": "string" }
            },
            "required": ["id"]
          }
        ]
      }
    },
    "properties": {
      "type": "array",
      "description": "Fixed property values set by this deployable. Merged with resolved parameters.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "value": { "type": ["string", "number", "boolean"] },
          "default": { "type": ["string", "number", "boolean"] },
          "description": { "type": "string" },
          "required": {
            "type": "boolean",
            "description": "Override the required-flag of the parameter with this id (defined in a template)."
          }
        },
        "required": ["id"],
        "anyOf": [
          { "required": ["value"] },
          { "required": ["default"] },
          { "required": ["required"] }
        ]
      }
    },
    "parameterOverrides": {
      "type": "array",
      "description": "Override name/description of parameters defined in templates",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["id"]
      }
    }
  },
  "required": ["name"]
}
