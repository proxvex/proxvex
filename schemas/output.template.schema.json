{
  "$id": "output.template",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "default": { "type": "boolean" },
        "optional": {
          "type": "boolean",
          "default": false,
          "description": "Optional output: may or may not be produced at runtime. Allows the same output ID to be set by another template without conflict."
        }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    { "type": "string" }
  ]
}
