{
  "$id": "templatelist",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "position": { "type": "string", "enum": ["start", "end"] },
          "before": { "type": "string" },
          "after": { "type": "string" }
        },
        "required": ["name"],
        "additionalProperties": false
      },
      { "type": "string" }
    ]
  }
}
