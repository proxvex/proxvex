#!/bin/sh
# Pre-commit hook: catch JSON schema + container-state coherence drift
# before the commit lands.
#
# Triggers (per staged files):
#   - any JSON under json/ or schemas/  → run `pnpm run lint:json` (validateAllJson)
#   - any backend TS/MTS source         → run `pnpm run build` first, then lint:json
#                                          (validateAllJson is loaded from dist/)
#
# Skip with: git commit --no-verify
#
# Speed: lint:json takes ~5s on a hot cache. We avoid running it for commits
# that touch only docs / production scripts / cli.

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Collect staged files (added/copied/modified/renamed). --diff-filter=ACMR
# excludes deletes — a deleted file can't break a schema check.
staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged" ]; then
  exit 0
fi

# Decide what to do based on what changed.
needs_lint=0
needs_build=0
while IFS= read -r f; do
  case "$f" in
    json/*.json|json/**/*.json|schemas/*.json|schemas/**/*.json)
      needs_lint=1
      ;;
    backend/src/*|backend/src/**/*)
      case "$f" in
        *.mts|*.ts|*.cts|*.mjs|*.js)
          needs_lint=1
          needs_build=1
          ;;
      esac
      ;;
    backend/package.json|backend/tsconfig*.json)
      needs_lint=1
      needs_build=1
      ;;
  esac
done <<EOF
$staged
EOF

if [ "$needs_lint" -eq 0 ]; then
  exit 0
fi

cd backend

if [ "$needs_build" -eq 1 ]; then
  printf "${YELLOW}==> Backend changed — building before lint...${NC}\n"
  if ! pnpm run build; then
    printf "${RED}✖ build failed — aborting commit. Fix errors or skip with --no-verify.${NC}\n"
    exit 1
  fi
fi

printf "${YELLOW}==> Running lint:json (validateAllJson + container-state coherence)...${NC}\n"
if ! pnpm run lint:json; then
  printf "${RED}✖ lint:json failed — aborting commit. Fix errors or skip with --no-verify.${NC}\n"
  exit 1
fi

printf "${GREEN}✓ pre-commit checks passed${NC}\n"
